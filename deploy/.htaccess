# ============================================================================
# KON'art — Configuration Apache pour Hostinger
# Place ce fichier à la racine de public_html/
# ============================================================================

# ----------------------------------------------------------------------------
# 1. Force HTTPS (redirige http vers https)
# ----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redirige www vers non-www (commenté — décommentez si vous préférez)
  # RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  # RewriteRule ^(.*)$ https://%1/$1 [L,R=301]
</IfModule>

# ----------------------------------------------------------------------------
# 2. Compression gzip — réduit la taille des fichiers transférés
# ----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/rss+xml application/atom+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>

# ----------------------------------------------------------------------------
# 3. Cache navigateur — accélère les visites répétées
# ----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                              "access plus 1 month"

  # HTML : pas de cache long (pour qu'une mise à jour soit visible vite)
  ExpiresByType text/html                     "access plus 1 hour"

  # Images
  ExpiresByType image/jpg                     "access plus 1 year"
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"

  # Fonts (Google Fonts charge depuis externe, pas concerné)
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"

  # JS / CSS
  ExpiresByType text/css                      "access plus 1 month"
  ExpiresByType application/javascript        "access plus 1 month"

  # PDF (le CV)
  ExpiresByType application/pdf               "access plus 1 month"
</IfModule>

# ----------------------------------------------------------------------------
# 4. Sécurité — headers basiques
# ----------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "interest-cohort=()"
</IfModule>

# ----------------------------------------------------------------------------
# 5. MIME types — au cas où Hostinger ne les détecte pas
# ----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/svg+xml                       .svg
  AddType application/pdf                     .pdf
  AddType text/css                            .css
  AddType application/javascript              .js
</IfModule>

# ----------------------------------------------------------------------------
# 6. Page d'erreur custom (optionnel — décommentez si vous créez 404.html)
# ----------------------------------------------------------------------------
# ErrorDocument 404 /404.html

# ----------------------------------------------------------------------------
# 7. Empêcher le listing des dossiers
# ----------------------------------------------------------------------------
Options -Indexes

# ----------------------------------------------------------------------------
# 8. Page d'accueil par défaut
# ----------------------------------------------------------------------------
DirectoryIndex index.html
